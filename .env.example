# ----------------------------------------------------------------------------
# Synapse environment. Copy to `.env` and fill in what you have.
# The app RUNS WITH NONE of these set (mock AI + native browser voice + SQLite).
# Add keys to unlock real models.
# ----------------------------------------------------------------------------

# Database — SQLite by default. Swap for a Postgres URL in production.
DATABASE_URL="file:./dev.db"

# Auth — generate a long random string for production.
JWT_SECRET="dev-only-change-me-to-a-long-random-string"

# ---- AI provider (modular) -------------------------------------------------
# Which provider the AI layer uses: "mock" | "anthropic"
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
# Default model id (modular — swap freely)
AI_MODEL="claude-sonnet-4-6"

# ---- Voice (optional) ------------------------------------------------------
# Browser Web Speech API is used by default (no key). Set to use ElevenLabs.
ELEVENLABS_API_KEY=""

# ---- Payments (optional) ---------------------------------------------------
# Premium is a one-time $10 unlock. Without Stripe keys, a dev-bypass unlock
# button is shown so you can exercise the premium flows locally.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Public base URL (used for redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
